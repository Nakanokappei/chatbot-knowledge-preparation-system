{
  "family": "ckps-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::444332185803:role/ckps-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::444332185803:role/ckps-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "worker",
      "image": "444332185803.dkr.ecr.ap-northeast-1.amazonaws.com/ckps-worker:latest",
      "essential": true,
      "environment": [
        { "name": "SQS_QUEUE_URL", "value": "REPLACE_WITH_SQS_QUEUE_URL" },
        { "name": "SQS_REGION", "value": "ap-northeast-1" },
        { "name": "S3_BUCKET", "value": "knowledge-prep-data-dev" },
        { "name": "S3_REGION", "value": "ap-northeast-1" },
        { "name": "LOG_LEVEL", "value": "INFO" }
      ],
      "secrets": [
        {
          "name": "DB_HOST",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:444332185803:secret:ckps/db-XXXXXX:host::"
        },
        {
          "name": "DB_PORT",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:444332185803:secret:ckps/db-XXXXXX:port::"
        },
        {
          "name": "DB_NAME",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:444332185803:secret:ckps/db-XXXXXX:dbname::"
        },
        {
          "name": "DB_USER",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:444332185803:secret:ckps/db-XXXXXX:username::"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:444332185803:secret:ckps/db-XXXXXX:password::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ckps-worker",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "worker"
        }
      },
      "stopTimeout": 30
    }
  ]
}
