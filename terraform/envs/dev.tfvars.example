# ============================================================
# Development Environment Overrides
# ============================================================
# Usage:
#   terraform plan  -var-file=envs/dev.tfvars
#   terraform apply -var-file=envs/dev.tfvars
# ============================================================

environment          = "dev"

# Use the smallest Graviton-based instance for cost savings
db_instance_class    = "db.t4g.micro"

# Minimal compute for the web application container
app_cpu              = 256
app_memory           = 512

# The worker needs more headroom for embedding / clustering
worker_cpu           = 1024
worker_memory        = 2048

# Single replica is sufficient in development
app_desired_count    = 1
worker_desired_count = 1

# Restrict ALB access to office networks only
allowed_cidr_blocks = [
  # "x.x.x.x/32",  # Add your office IP ranges here
]

# Custom domain + HTTPS (leave empty to skip)
domain_name      = ""
hosted_zone_name = ""

# GitHub Actions CI/CD (owner/repo format)
github_repo = ""
